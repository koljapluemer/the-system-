{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "The System note file",
  "description": "Schema for the flat JSON note files stored in the data folder. A conforming file matches exactly one of the note shapes this app currently reads and writes: scratchpad, art, hypothesis, milestone, gestalt, context, ifThen, description, quote, source, entity, story, log, flashcard, project, do, or activity.",
  "definitions": {
    "rels": {
      "description": "Relationships to other note files: [label, filename] or [label, filename, mirrorLabel] — the optional third element records the reciprocal label written on the related note.",
      "type": "array",
      "items": {
        "type": "array",
        "items": [
          { "type": "string" },
          { "type": "string" },
          { "type": "string" }
        ],
        "minItems": 2,
        "maxItems": 3
      }
    },
    "triaged": {
      "description": "Written by the triage flows once a note has been kept.",
      "type": "string",
      "enum": ["true"]
    },
    "aliases": {
      "description": "Alternate names for this note.",
      "type": "array",
      "items": { "type": "string" }
    },
    "extraData": {
      "description": "Arbitrary nested props imported from Obsidian frontmatter (see the \"Add props from Obsidian\" action on a note's view screen), preserved as-is. Not otherwise read or written by the app.",
      "type": "object"
    },
    "questions": {
      "description": "Netting-flow question/answer pairs, keyed by the (plaintext) question text. Value is the free-text answer, or literally false if the question was marked not relevant, so Netting skips it for this note from then on.",
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "const": false }
        ]
      }
    }
  },
  "oneOf": [
    {
      "description": "Scratchpad Triage notes.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "scratchpad" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title", "content"],
      "additionalProperties": false
    },
    {
      "description": "Art Triage notes.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "art" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title", "content"],
      "additionalProperties": false
    },
    {
      "description": "Hypotheses tracked through a research workflow: context, notes, and findings logged as free-text entries, resolved as supported or disproven.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "hypothesis" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "secondaryType": {
          "type": "string",
          "enum": ["active", "supported", "disproven"],
          "defaultVisible": ["active"]
        },
        "context": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "array", "items": { "type": "string" } },
        "findings": { "type": "array", "items": { "type": "string" } },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Milestone notes: a status marker (open, failed, or soso) with a free-text description.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "milestone" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "secondaryType": {
          "type": "string",
          "enum": ["open", "failed", "soso", "success"],
          "defaultVisible": ["open"]
        },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Log notes: a timestamped free-text entry attached to a hypothesis, source, or milestone.",
      "showInLists": false,
      "type": "object",
      "properties": {
        "primaryType": { "const": "log" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "createdAt": {
          "description": "ISO 8601 timestamp stamped automatically at creation.",
          "type": "string"
        },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title", "createdAt"],
      "additionalProperties": false
    },
    {
      "description": "Gestalt notes: a pattern, approximated by descriptions.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "gestalt" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Context notes: gives context to if-then note.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "context" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "If/then notes: a type of take.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "ifThen" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" },
        "questions": { "$ref": "#/definitions/questions" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Description notes: describes a shape.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "description" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" },
        "questions": { "$ref": "#/definitions/questions" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Quote notes: a verbatim quote worth keeping.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "quote" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Source notes: a reference to where a note or idea came from.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "source" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "secondaryType": {
          "type": "string",
          "enum": ["book", "article", "blog", "video", "software", "misc"]
        },
        "worthCheckingOutAgain": { "type": "boolean" },
        "url": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Entity notes: a person, place, organization, or other named thing.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "entity" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "url": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Story notes: a narrative account worth keeping.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "story" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Project notes: a project tracked by status.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "project" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "secondaryType": {
          "type": "string",
          "enum": ["idea", "active", "abandoned", "frozen"]
        },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Do notes: an actionable item tracked by status.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "do" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "secondaryType": {
          "type": "string",
          "enum": ["idea", "started", "done", "wont"]
        },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Activity notes: a logged activity worth keeping track of.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "activity" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Flashcard notes: a front/back pair reviewed by the Memorize flow using FSRS spaced-repetition scheduling.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "flashcard" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "front": { "type": "string" },
        "back": { "type": "string" },
        "fsrs": {
          "description": "Serialized fsrs.Card learning data (see lib/services/fsrs_service.dart), absent until the card is first practiced in the Memorize flow.",
          "type": ["object", "null"]
        },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" }
      },
      "required": ["primaryType", "title", "front", "back"],
      "additionalProperties": false
    }
  ]
}
