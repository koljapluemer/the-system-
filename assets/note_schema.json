{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "The System note file",
  "description": "Schema for the flat JSON note files stored in the data folder. A conforming file matches exactly one of the note shapes this app currently reads and writes: scratchpad, art, hypothesis, milestone, gestalt, context, ifThen, description, quote, source, entity, or story.",
  "definitions": {
    "rels": {
      "description": "Relationships to other note files, e.g. [\"source\", \"other-note.json\"].",
      "type": "array",
      "items": {
        "type": "array",
        "items": [
          { "type": "string" },
          { "type": "string" }
        ],
        "minItems": 2,
        "maxItems": 2
      }
    },
    "triaged": {
      "description": "Written by the triage flows once a note has been kept.",
      "type": "string",
      "enum": ["true"]
    },
    "aliases": {
      "description": "Alternate names for this note.",
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "oneOf": [
    {
      "description": "Scratchpad Triage notes.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "scratchpad" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "body": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title", "body"],
      "additionalProperties": false
    },
    {
      "description": "Art Triage notes.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "art" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title", "content"],
      "additionalProperties": false
    },
    {
      "description": "Hypotheses tracked through a research workflow: context, experiment, notes, and findings logged as free-text entries, resolved as supported or disproven.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "hypothesis" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "secondaryType": {
          "type": "string",
          "enum": ["active", "supported", "disproven"],
          "defaultVisible": ["active"]
        },
        "context": { "type": "array", "items": { "type": "string" } },
        "experiment": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "array", "items": { "type": "string" } },
        "findings": { "type": "array", "items": { "type": "string" } },
        "rels": { "$ref": "#/definitions/rels" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Milestone notes: a status marker (open, failed, or soso) with a free-text description.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "milestone" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "secondaryType": {
          "type": "string",
          "enum": ["open", "failed", "soso"],
          "defaultVisible": ["open"]
        },
        "rels": { "$ref": "#/definitions/rels" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Gestalt notes: a pattern, approximated by descriptions.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "gestalt" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Context notes: gives context to if-then note.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "context" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "If/then notes: a type of take.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "ifThen" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Description notes: describes a shape.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "description" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Quote notes: a verbatim quote worth keeping.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "quote" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Source notes: a reference to where a note or idea came from.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "source" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "secondaryType": {
          "type": "string",
          "enum": ["book", "article", "blog", "video", "software", "misc"]
        },
        "rels": { "$ref": "#/definitions/rels" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Entity notes: a person, place, organization, or other named thing.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "entity" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Story notes: a narrative account worth keeping.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "story" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    }
  ]
}
