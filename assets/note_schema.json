{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "The System note file",
  "description": "Schema for the flat JSON note files stored in the data folder. A conforming file matches exactly one of the note shapes this app currently reads and writes: art, milestone, story, log, flashcard, project, do, activity, or question.",
  "definitions": {
    "rels": {
      "description": "Relationships to other note files: [label, filename] or [label, filename, mirrorLabel] — the optional third element records the reciprocal label written on the related note.",
      "type": "array",
      "items": {
        "type": "array",
        "items": [
          { "type": "string" },
          { "type": "string" },
          { "type": "string" }
        ],
        "minItems": 2,
        "maxItems": 3
      }
    },
    "triaged": {
      "description": "Written by the triage flows once a note has been kept.",
      "type": "string",
      "enum": ["true"]
    },
    "aliases": {
      "description": "Alternate names for this note.",
      "type": "array",
      "items": { "type": "string" }
    },
    "extraData": {
      "description": "Arbitrary nested props imported from Obsidian frontmatter (see the \"Add props from Obsidian\" action on a note's view screen), preserved as-is. Not otherwise read or written by the app.",
      "type": "object"
    }
  },
  "oneOf": [
    {
      "description": "Art Triage notes.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "art" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title", "content"],
      "additionalProperties": false
    },
    {
      "description": "Milestone notes: a status marker (open, failed, or soso) with a free-text description.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "milestone" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "secondaryType": {
          "type": "string",
          "enum": ["open", "failed", "soso", "success"],
          "defaultVisible": ["open"]
        },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Log notes: a timestamped free-text entry attached to a milestone.",
      "showInLists": false,
      "type": "object",
      "properties": {
        "primaryType": { "const": "log" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "createdAt": {
          "description": "ISO 8601 timestamp stamped automatically at creation.",
          "type": "string"
        },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title", "createdAt"],
      "additionalProperties": false
    },
    {
      "description": "Story notes: a narrative account worth keeping.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "story" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Question notes: an open question worth keeping track of.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "question" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Project notes: a project tracked by status.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "project" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "secondaryType": {
          "type": "string",
          "enum": ["idea", "active", "abandoned", "frozen"]
        },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Do notes: an actionable item tracked by status.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "do" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "secondaryType": {
          "type": "string",
          "enum": ["idea", "started", "done", "wont"]
        },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Activity notes: a logged activity worth keeping track of.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "activity" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "content": { "type": "string" },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" },
        "triaged": { "$ref": "#/definitions/triaged" }
      },
      "required": ["primaryType", "title"],
      "additionalProperties": false
    },
    {
      "description": "Flashcard notes: a front/back pair reviewed by the Memorize flow using FSRS spaced-repetition scheduling.",
      "showInLists": true,
      "type": "object",
      "properties": {
        "primaryType": { "const": "flashcard" },
        "title": { "type": "string" },
        "aliases": { "$ref": "#/definitions/aliases" },
        "front": { "type": "string" },
        "back": { "type": "string" },
        "fsrs": {
          "description": "Serialized fsrs.Card learning data (see lib/services/fsrs_service.dart), absent until the card is first practiced in the Memorize flow.",
          "type": ["object", "null"]
        },
        "rels": { "$ref": "#/definitions/rels" },
        "extraData": { "$ref": "#/definitions/extraData" }
      },
      "required": ["primaryType", "title", "front", "back"],
      "additionalProperties": false
    }
  ]
}
